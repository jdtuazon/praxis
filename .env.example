# ─────────────────────────────────────────────────────────────────────────────
# Praxis configuration. Copy to `.env` and fill in.   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM provider ─────────────────────────────────────────────────────────────
# Which provider drives planning/synthesis/validation reasoning.
#   openrouter | anthropic | openai
PRAXIS_LLM_PROVIDER=openrouter

# OpenRouter — one key, any model (OpenAI-compatible gateway).
#   Get a key:      https://openrouter.ai/keys
#   Browse models:  https://openrouter.ai/models
OPENROUTER_API_KEY=
# Model slug MUST be namespaced (provider/model) for OpenRouter. Examples:
#   anthropic/claude-3.5-sonnet · openai/gpt-4o · google/gemini-2.0-flash-001
# A strong model improves planning & synthesis quality.
PRAXIS_LLM_MODEL=anthropic/claude-3.5-sonnet

# ── Other providers (set PRAXIS_LLM_PROVIDER above to switch) ──────────────────
# Anthropic (native). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
#   then set PRAXIS_LLM_MODEL=claude-sonnet-4-6   (native, non-namespaced slug)

# OpenAI (native).
OPENAI_API_KEY=
#   then set PRAXIS_LLM_MODEL=gpt-4o

# Optional: override the OpenAI-compatible base URL. OpenRouter is auto-configured,
# so only set this for a self-hosted or alternative compatible endpoint.
# PRAXIS_LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Platform: Linear ─────────────────────────────────────────────────────────
# Personal API key from Linear → Settings → Security & access → API keys.
# https://linear.app/settings/api      (a free workspace is enough)
LINEAR_API_KEY=
# Linear GraphQL endpoint (rarely needs changing).
LINEAR_API_URL=https://api.linear.app/graphql

# ── Memory ───────────────────────────────────────────────────────────────────
# Where the persistent memory DB lives. Survives across runs & sessions.
PRAXIS_MEMORY_PATH=.praxis/memory.sqlite

# ── Synthesis ────────────────────────────────────────────────────────────────
# Max attempts before the synthesizer gives up and reports clearly.
PRAXIS_SYNTHESIS_MAX_ATTEMPTS=3

# ── Safety ───────────────────────────────────────────────────────────────────
# Reserved for the (gated, opt-in) destructive create-canary-then-rollback
# synthesis test tier. The shipped synthesizer validates with NON-destructive
# tiers only (schema-check + dry-run); see ARCHITECTURE.md "what's next".
PRAXIS_REQUIRE_ROLLBACK_JOURNAL=true
# PRAXIS_SANDBOX_TEAM_KEY=         # team to confine destructive canaries to (unused until that tier is wired)
